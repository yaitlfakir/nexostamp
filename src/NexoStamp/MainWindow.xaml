<Window x:Class="NexoStamp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NexoStamp"
        xmlns:services="clr-namespace:NexoStamp.Services"
        mc:Ignorable="d"
        Title="NexoStamp - Stamp Design Application" Height="700" Width="1200"
        WindowState="Maximized"
        FlowDirection="{Binding FlowDirection}">
    <Window.Resources>
        <services:LocalizationService x:Key="Localization"/>
    </Window.Resources>
    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem x:Name="FileMenuItem" Header="_File">
                <MenuItem x:Name="NewMenuItem" Header="_New" Click="NewDesign_Click" InputGestureText="Ctrl+N"/>
                <MenuItem x:Name="OpenMenuItem" Header="_Open..." Click="OpenDesign_Click" InputGestureText="Ctrl+O"/>
                <MenuItem x:Name="SaveMenuItem" Header="_Save" Click="SaveDesign_Click" InputGestureText="Ctrl+S"/>
                <MenuItem x:Name="SaveAsMenuItem" Header="Save _As..." Click="SaveDesignAs_Click"/>
                <Separator/>
                <MenuItem x:Name="SaveAsTemplateMenuItem" Header="Save as _Template..." Click="SaveAsTemplate_Click"/>
                <Separator/>
                <MenuItem x:Name="PrintPreviewMenuItem" Header="_Print Preview..." Click="PrintPreview_Click" InputGestureText="Ctrl+P"/>
                <MenuItem x:Name="PrintMenuItem" Header="Print..." Click="Print_Click"/>
                <Separator/>
                <MenuItem x:Name="ExitMenuItem" Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem x:Name="EditMenuItem" Header="_Edit">
                <MenuItem x:Name="UndoMenuItem" Header="_Undo" Click="Undo_Click" InputGestureText="Ctrl+Z"/>
                <MenuItem x:Name="RedoMenuItem" Header="_Redo" Click="Redo_Click" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem x:Name="DeleteMenuItem" Header="_Delete" Click="Delete_Click" InputGestureText="Del"/>
                <MenuItem x:Name="DuplicateMenuItem" Header="_Duplicate" Click="Duplicate_Click" InputGestureText="Ctrl+D"/>
            </MenuItem>
            <MenuItem x:Name="TemplatesMenuItem" Header="_Templates">
                <!-- Round Stamps (Standard Sizes) -->
                <MenuItem Header="Round Stamps">
                    <MenuItem Header="Round 20mm" Click="LoadTemplate_Click" Tag="round-20mm.nxs"/>
                    <MenuItem Header="Round 25mm" Click="LoadTemplate_Click" Tag="round-25mm.nxs"/>
                    <MenuItem Header="Round 30mm" Click="LoadTemplate_Click" Tag="round-30mm.nxs"/>
                    <MenuItem Header="Round 35mm" Click="LoadTemplate_Click" Tag="round-35mm.nxs"/>
                    <MenuItem Header="Round 40mm" Click="LoadTemplate_Click" Tag="round-40mm.nxs"/>
                </MenuItem>
                <!-- Rectangular Stamps (Standard Sizes) -->
                <MenuItem Header="Rectangular Stamps">
                    <MenuItem Header="Rectangular 25mm" Click="LoadTemplate_Click" Tag="rect-25mm.nxs"/>
                    <MenuItem Header="Rectangular 40x25mm" Click="LoadTemplate_Click" Tag="rect-40x25mm.nxs"/>
                    <MenuItem Header="Rectangular 60x40mm" Click="LoadTemplate_Click" Tag="rect-60x40mm.nxs"/>
                    <MenuItem Header="Rectangular 100x60mm" Click="LoadTemplate_Click" Tag="rect-100x60mm.nxs"/>
                </MenuItem>
                <!-- Format Templates -->
                <MenuItem Header="Format Templates">
                    <MenuItem Header="Round Dual Circle" Click="LoadTemplate_Click" Tag="round-dual-circle.nxs"/>
                    <MenuItem Header="Round Official" Click="LoadTemplate_Click" Tag="round-official.nxs"/>
                    <MenuItem Header="Round Certified" Click="LoadTemplate_Click" Tag="round-certified.nxs"/>
                    <MenuItem Header="Round Approved" Click="LoadTemplate_Click" Tag="round-approved.nxs"/>
                    <MenuItem Header="Round Medical" Click="LoadTemplate_Click" Tag="round-medical.nxs"/>
                    <MenuItem Header="Rectangular Company" Click="LoadTemplate_Click" Tag="rectangular-company.nxs"/>
                </MenuItem>
            </MenuItem>
            <MenuItem x:Name="HelpMenuItem" Header="_Help">
                <MenuItem x:Name="AboutMenuItem" Header="_About" Click="About_Click"/>
            </MenuItem>
            <MenuItem x:Name="LanguageMenu" Header="_Language">
                <MenuItem x:Name="EnglishMenuItem" Header="English" Click="EnglishMenuItem_Click"/>
                <MenuItem x:Name="ArabicMenuItem" Header="العربية (Arabic)" Click="ArabicMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Height="50">
            <Button x:Name="AddTextButton" Click="AddText_Click" ToolTip="Add Text" Padding="8">
                <StackPanel>
                    <TextBlock Text="T" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Text" FontSize="9"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button x:Name="AddRectangleButton" Click="AddRectangle_Click" ToolTip="Add Rectangle" Padding="8">
                <StackPanel>
                    <Rectangle Width="24" Height="18" Stroke="Black" StrokeThickness="2"/>
                    <TextBlock Text="Rectangle" FontSize="9"/>
                </StackPanel>
            </Button>
            <Button x:Name="AddCircleButton" Click="AddCircle_Click" ToolTip="Add Circle" Padding="8">
                <StackPanel>
                    <Ellipse Width="24" Height="24" Stroke="Black" StrokeThickness="2"/>
                    <TextBlock Text="Circle" FontSize="9"/>
                </StackPanel>
            </Button>
            <Button x:Name="AddCircularStampButton" Click="AddCircularStamp_Click" ToolTip="Circular Stamp Template" Padding="8">
                <StackPanel>
                    <Ellipse Width="24" Height="24" Stroke="Black" StrokeThickness="2">
                        <Ellipse.Fill>
                            <VisualBrush Stretch="Uniform">
                                <VisualBrush.Visual>
                                    <TextBlock Text="S" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="Circle Stamp" FontSize="9"/>
                </StackPanel>
            </Button>
            <Button x:Name="AddCurvedTextButton" Click="AddCurvedText_Click" ToolTip="Add Curved Text" Padding="8">
                <StackPanel>
                    <Path Data="M 5,15 A 10,10 0 0 1 20,15" Stroke="Black" StrokeThickness="2"/>
                    <TextBlock Text="Curved Text" FontSize="9"/>
                </StackPanel>
            </Button>
            <Button x:Name="AddLineButton" Click="AddLine_Click" ToolTip="Add Line" Padding="8">
                <StackPanel>
                    <Line X1="0" Y1="12" X2="24" Y2="12" Stroke="Black" StrokeThickness="2"/>
                    <TextBlock Text="Line" FontSize="9"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Button x:Name="SizeCalculatorButton" Click="OpenSizeCalculator_Click" ToolTip="Size Calculator (mm)" Padding="8">
                <StackPanel>
                    <TextBlock Text="mm" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="Size" FontSize="9"/>
                </StackPanel>
            </Button>
            <Button x:Name="MultiSelectButton" Click="ToggleMultiSelect_Click" ToolTip="Toggle Multi-Select Mode" Padding="8">
                <StackPanel>
                    <TextBlock Text="M+" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="Multi" FontSize="9"/>
                </StackPanel>
            </Button>
            <Separator/>
            <Label x:Name="ZoomLabelControl" Content="Zoom:" VerticalAlignment="Center"/>
            <Slider x:Name="ZoomSlider" Width="150" Minimum="0.1" Maximum="3" Value="1"
                    TickFrequency="0.1" ValueChanged="ZoomSlider_ValueChanged"
                    VerticalAlignment="Center"/>
            <TextBlock x:Name="ZoomLabel" Text="100%" VerticalAlignment="Center" Margin="5,0"/>
        </ToolBar>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="SizeDisplayText" Text="Size: 0×0 mm"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="MultiSelectStatusText" Text="Single Select" Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content Area -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- Design Canvas Area -->
            <Border Grid.Column="0" Background="#E0E0E0" Padding="10">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Border BorderBrush="Gray" BorderThickness="2" Background="White">
                        <Viewbox x:Name="CanvasViewbox" Stretch="Uniform">
                            <Canvas x:Name="DesignCanvas" 
                                    Width="400" Height="300" 
                                    Background="Black"
                                    MouseLeftButtonDown="DesignCanvas_MouseLeftButtonDown"
                                    MouseMove="DesignCanvas_MouseMove"
                                    MouseLeftButtonUp="DesignCanvas_MouseLeftButtonUp">
                            </Canvas>
                        </Viewbox>
                    </Border>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Properties Panel -->
            <DockPanel Grid.Column="2" Background="#F5F5F5">
                <TextBlock x:Name="PropertiesTitleText" DockPanel.Dock="Top" Text="Properties" FontSize="16" FontWeight="Bold"
                           Padding="10" Background="#D0D0D0"/>
                <ScrollViewer>
                    <StackPanel x:Name="PropertiesPanel" Margin="10">
                        <TextBlock x:Name="NoSelectionText" Text="No element selected" FontStyle="Italic"/>

                        <!-- Text Properties -->
                        <StackPanel x:Name="TextPropertiesPanel" Visibility="Collapsed">
                            <TextBlock x:Name="TextPropertiesTitle" Text="Text Properties" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Label x:Name="TextLabel" Content="Text:"/>
                            <TextBox x:Name="TextContentBox" TextChanged="TextContent_Changed"/>

                            <Label x:Name="FontFamilyLabel" Content="Font Family:" Margin="0,10,0,0"/>
                            <ComboBox x:Name="FontFamilyComboBox" SelectionChanged="FontFamily_Changed"/>

                            <Label x:Name="FontSizeLabelProp" Content="Font Size:" Margin="0,10,0,0"/>
                            <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="72"
                                    TickFrequency="2" ValueChanged="FontSize_Changed"/>
                            <TextBlock x:Name="FontSizeLabel" TextAlignment="Center"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <CheckBox x:Name="BoldCheckBox" Content="Bold" Margin="0,0,10,0"
                                          Checked="FontStyle_Changed" Unchecked="FontStyle_Changed"/>
                                <CheckBox x:Name="ItalicCheckBox" Content="Italic"
                                          Checked="FontStyle_Changed" Unchecked="FontStyle_Changed"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Curved Text Properties -->
                        <StackPanel x:Name="CurvedTextPropertiesPanel" Visibility="Collapsed">
                            <TextBlock x:Name="CurvedTextPropertiesTitle" Text="Curved Text Properties" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Label x:Name="CurvedTextLabel" Content="Text:"/>
                            <TextBox x:Name="CurvedTextContentBox" TextChanged="CurvedTextContent_Changed"/>

                            <Label x:Name="CurvedFontFamilyLabel" Content="Font Family:" Margin="0,10,0,0"/>
                            <ComboBox x:Name="CurvedFontFamilyComboBox" SelectionChanged="CurvedFontFamily_Changed"/>

                            <Label x:Name="CurvedFontSizeLabelProp" Content="Font Size:" Margin="0,10,0,0"/>
                            <Slider x:Name="CurvedFontSizeSlider" Minimum="8" Maximum="72"
                                    TickFrequency="2" ValueChanged="CurvedFontSize_Changed"/>
                            <TextBlock x:Name="CurvedFontSizeLabel" TextAlignment="Center"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <CheckBox x:Name="CurvedBoldCheckBox" Content="Bold" Margin="0,0,10,0"
                                          Checked="CurvedFontStyle_Changed" Unchecked="CurvedFontStyle_Changed"/>
                                <CheckBox x:Name="CurvedItalicCheckBox" Content="Italic"
                                          Checked="CurvedFontStyle_Changed" Unchecked="CurvedFontStyle_Changed"/>
                            </StackPanel>

                            <Separator Margin="0,10"/>

                            <Label x:Name="RadiusLabel" Content="Radius:"/>
                            <Slider x:Name="CurveRadiusSlider" Minimum="10" Maximum="500" Value="100"
                                    ValueChanged="CurveRadius_Changed"/>
                            <TextBlock x:Name="CurveRadiusLabel" TextAlignment="Center"/>

                            <Label x:Name="StartAngleLabel" Content="Start Angle:"/>
                            <Slider x:Name="CurveStartAngleSlider" Minimum="0" Maximum="360" Value="0"
                                    ValueChanged="CurveStartAngle_Changed"/>
                            <TextBlock x:Name="CurveStartAngleLabel" TextAlignment="Center"/>

                            <Label x:Name="EndAngleLabel" Content="End Angle:"/>
                            <Slider x:Name="CurveEndAngleSlider" Minimum="0" Maximum="360" Value="360"
                                    ValueChanged="CurveEndAngle_Changed"/>
                            <TextBlock x:Name="CurveEndAngleLabel" TextAlignment="Center"/>

                            <CheckBox x:Name="CurveInvertedCheckBox" Content="Invert Direction"
                                      Checked="CurveInverted_Changed" Unchecked="CurveInverted_Changed"/>
                        </StackPanel>

                        <!-- Shape Properties -->
                        <StackPanel x:Name="ShapePropertiesPanel" Visibility="Collapsed">
                            <TextBlock x:Name="ShapePropertiesTitle" Text="Shape Properties" FontWeight="Bold" Margin="0,0,0,5"/>
                            <Label x:Name="StrokeThicknessLabel" Content="Stroke Thickness:" Margin="0,10,0,0"/>
                            <Slider x:Name="StrokeThicknessSlider" Minimum="1" Maximum="10"
                                    TickFrequency="1" ValueChanged="StrokeThickness_Changed"/>
                            <TextBlock x:Name="StrokeThicknessLabelValue" TextAlignment="Center"/>
                        </StackPanel>

                        <!-- Circle Properties -->
                        <StackPanel x:Name="CirclePropertiesPanel" Visibility="Collapsed">
                            <TextBlock x:Name="CirclePropertiesTitle" Text="Circle Properties" FontWeight="Bold" Margin="0,0,0,5"/>

                            <!-- Radius slider (links Width/Height) -->
                            <Label x:Name="RadiusLabelProp" Content="Radius:"/>
                            <Slider x:Name="CircleRadiusSlider" Minimum="10" Maximum="300"
                                    TickFrequency="5" ValueChanged="CircleRadius_Changed"/>
                            <TextBlock x:Name="CircleRadiusLabel" TextAlignment="Center"/>

                            <!-- Keep Square checkbox -->
                            <CheckBox x:Name="KeepSquareCheckBox" Content="Keep Circle (W = H)" Margin="0,10,0,0"
                                      Checked="KeepSquare_Changed" Unchecked="KeepSquare_Changed"/>

                            <!-- Center Inside button -->
                            <Separator Margin="0,10"/>
                            <Button x:Name="CenterInsideButton" Content="Center Inside Selected"
                                    Click="CenterInside_Click" Margin="0,5,0,0" Padding="5"/>
                            <TextBlock x:Name="CenterInsideHint" Text="(Select target circle first)"
                                       FontSize="9" Foreground="Gray" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Common Properties -->
                        <StackPanel x:Name="CommonPropertiesPanel" Visibility="Collapsed">
                            <Label x:Name="PositionLabel" Content="Position:" Margin="0,10,0,0"/>
                            <StackPanel Orientation="Horizontal">
                                <Label x:Name="XLabel" Content="X:"/>
                                <TextBox x:Name="PositionXBox" Width="50" TextChanged="Position_Changed"/>
                            </StackPanel>
                            <Slider x:Name="PositionXSlider" Minimum="0" Maximum="400"
                                    TickFrequency="10" ValueChanged="PositionXSlider_Changed"/>
                            <TextBlock x:Name="PositionXSliderLabel" TextAlignment="Center" FontSize="10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <Label x:Name="YLabel" Content="Y:"/>
                                <TextBox x:Name="PositionYBox" Width="50" TextChanged="Position_Changed"/>
                            </StackPanel>
                            <Slider x:Name="PositionYSlider" Minimum="0" Maximum="300"
                                    TickFrequency="10" ValueChanged="PositionYSlider_Changed"/>
                            <TextBlock x:Name="PositionYSliderLabel" TextAlignment="Center" FontSize="10"/>

                            <Label x:Name="SizeLabel" Content="Size:" Margin="0,10,0,0"/>
                            <StackPanel Orientation="Horizontal">
                                <Label x:Name="WLabel" Content="W:"/>
                                <TextBox x:Name="WidthBox" Width="50" TextChanged="Size_Changed"/>
                            </StackPanel>
                            <Slider x:Name="WidthSlider" Minimum="10" Maximum="400"
                                    TickFrequency="5" ValueChanged="WidthSlider_Changed"/>
                            <TextBlock x:Name="WidthSliderLabel" TextAlignment="Center" FontSize="10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <Label x:Name="HLabel" Content="H:"/>
                                <TextBox x:Name="HeightBox" Width="50" TextChanged="Size_Changed"/>
                            </StackPanel>
                            <Slider x:Name="HeightSlider" Minimum="10" Maximum="300"
                                    TickFrequency="5" ValueChanged="HeightSlider_Changed"/>
                            <TextBlock x:Name="HeightSliderLabel" TextAlignment="Center" FontSize="10"/>

                            <Label x:Name="RotationLabelProp" Content="Rotation:" Margin="0,10,0,0"/>
                            <Slider x:Name="RotationSlider" Minimum="0" Maximum="360"
                                    TickFrequency="15" ValueChanged="Rotation_Changed"/>
                            <TextBlock x:Name="RotationLabel" TextAlignment="Center"/>

                            <!-- Center in Canvas button -->
                            <Separator Margin="0,10"/>
                            <Button x:Name="CenterInCanvasButton" Content="Center in Canvas"
                                    Click="CenterInCanvas_Click" Margin="0,5,0,0" Padding="5"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
